# Copia a .env y rellena (no subas .env a Git).

SECRET_KEY=cambia-esto-en-produccion

# API del agente WhatsApp (VPS): misma clave en el .env del bot (X-Bot-Key).
BOT_API_KEY=

# URL pública del sitio (sin barra final). Las fotos en /api/bot/* salen como https://...
PUBLIC_SITE_URL=https://TUUSUARIO.pythonanywhere.com

# Twilio (opcional, prueba admin)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# TWILIO_TEST_WHATSAPP_TO=+52...
