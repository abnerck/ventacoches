# URL pública del sitio en PythonAnywhere (sin barra final)
VENTACOCHES_API_BASE=https://gestorianacional.com.mx

# Misma clave que pongas en PythonAnywhere: BOT_API_KEY en .env del proyecto Flask
BOT_API_KEY=genera_una_clave_larga_aleatoria

# Sitio para prefijar rutas /static/... en mensajes (mismo dominio suele valer)
PUBLIC_SITE_URL=https://gestorianacional.com.mx

# WhatsApp (elige según tu librería: Twilio, Meta Cloud API, whatsapp-web.js, etc.)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Si usas OpenAI u otro LLM para el agente
# OPENAI_API_KEY=
