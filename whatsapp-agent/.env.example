# URL pública del sitio (misma que PUBLIC_SITE_URL en PythonAnywhere)
SITE_URL=https://gestorianacional.com.mx

# Igual que BOT_API_KEY en el .env del servidor Flask
BOT_API_KEY=tu-clave-larga-secreta

# https://platform.deepseek.com
DEEPSEEK_API_KEY=

# Opcional: solo responder a estos números (WhatsApp JID sin @c.us), separados por coma. Vacío = todos los chats privados.
# ALLOW_FROM=521234567890,5219988776655

# Instrucciones extra para el modelo (una línea; usa \n para salto de línea). Opcional.
# BOT_EXTRA_INSTRUCTIONS=Siempre menciona el horario Lun-Vie 9-18. No des descuentos.

# Archivo de texto con instrucciones (misma carpeta que index.js por defecto). Opcional.
# BOT_INSTRUCTIONS_FILE=instructions.txt

# Aviso de posible lead (interés en trámite o coche): WhatsApp del equipo, solo dígitos país+número, separados por coma.
# Ej. México: 5217778017434,5215512345678  → el bot envía un mensaje a esos chats cuando detecta interés claro.
# LEAD_NOTIFY_NUMBERS=5217778017434
